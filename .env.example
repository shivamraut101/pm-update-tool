# MongoDB (Atlas or local)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=YourApp
MONGODB_DB_NAME=pm_update_tool

# Reference DB (read-only - for pulling project/team data)
REF_MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=YourApp
REF_MONGODB_DB_NAME=live

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Email (Resend API - https://resend.com)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=updates@yourdomain.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
MANAGEMENT_TELEGRAM_CHAT_ID=your_management_telegram_chat_id_here

# App Config
TIMEZONE=Asia/Kolkata
DAILY_BRIEF_TIME=18:00
WEEKLY_REPORT_DAY=friday
WEEKLY_REPORT_TIME=18:00
REMINDER_NO_UPDATE_TIME=17:00

# Management contacts (comma-separated)
MANAGEMENT_EMAILS=boss@example.com
MANAGEMENT_CC_EMAILS=your_cc_email@example.com

# Alert emails (reminders/alerts sent to you)
ALERT_EMAILS=your_email@gmail.com
ALERT_CC_EMAILS=your_backup_email@gmail.com

# Deployment (set APP_URL to enable webhook mode for Telegram on Render/cloud)
# Leave empty for local development (uses long-polling)
APP_URL=

# Simple API key for basic auth
API_KEY=change_this_to_a_random_string